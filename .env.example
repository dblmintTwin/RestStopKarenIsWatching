# Copy this file to .env.local for local dev, and set these vars in your
# Vercel project settings for production.

# Neon Postgres connection string. Get it from the Neon project console:
# https://console.neon.tech/  ->  your project  ->  Connection Details
# Make sure the role/database matches the one where you ran db/schema.sql.
DATABASE_URL=postgres://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require
